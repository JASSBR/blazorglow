<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>BlazorGlow</PackageId>
    <Version>0.1.0</Version>
    <Authors>JASSBR</Authors>
    <Description>Beautiful animated UI components for Blazor. The Aceternity UI equivalent for .NET.</Description>
    <PackageTags>blazor;components;ui;animation;effects;css;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/JASSBR/blazorglow</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://blazorglow.dev</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.0" />
  </ItemGroup>

</Project>
